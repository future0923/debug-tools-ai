{
  "name": "debug-tools-ai",
  "version": "0.1.0",
  "description": "AI agent support package for DebugTools MCP workflows",
  "type": "module",
  "main": ".opencode/plugins/debug-tools-ai.js",
  "license": "MIT",
  "homepage": "https://github.com/future0923/debug-tools-ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/future0923/debug-tools-ai.git"
  },
  "bin": {
    "debug-tools-ai": "bin/debug-tools-ai"
  },
  "scripts": {
    "validate": "bash scripts/validate.sh",
    "doctor": "bash scripts/doctor.sh",
    "uninstall:local": "bash scripts/uninstall.sh",
    "check:versions": "bash scripts/check-versions.sh",
    "check:manifests": "bash scripts/check-manifest-paths.sh",
    "check:pressure": "bash scripts/check-pressure-scenarios.sh",
    "smoke:install": "bash scripts/smoke-install.sh",
    "package:release": "bash scripts/package-release.sh",
    "prepublish:check": "bash scripts/prepublish-check.sh"
  },
  "keywords": [
    "debug-tools",
    "mcp",
    "java",
    "intellij",
    "skills",
    "pi-package"
  ],
  "files": [
    "bin",
    "docs",
    "examples",
    "scripts",
    "skills",
    "tests/pressure",
    ".codex-plugin",
    ".claude-plugin",
    ".cursor-plugin",
    ".kimi-plugin",
    ".opencode",
    ".pi",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "install.sh",
    "gemini-extension.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./.pi/extensions/debug-tools-ai"
    ],
    "skills": [
      "./skills"
    ]
  }
}
